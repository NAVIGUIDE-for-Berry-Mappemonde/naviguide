# NAVIGUIDE API — Environment Variables Template
# Copy to .env and fill in your values (never commit .env to git)
#
# Docker / high-res land mask: `pyshp` is listed in requirements.txt for Natural Earth
# shapefiles under naviguide-api/geo_data/ (optional; global_land_mask still works without them).

# -- Copernicus Marine (existing) ---------------------------------------------
COPERNICUS_USERNAME=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# -- Anthropic Claude API — Simulation Mode Agents ----------------------------
# Required for the 4 AI agents (custom, guard, meteo, pirate)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -- Google Gemini — NavSecOps /duo routes ------------------------------------
GEMINI_API_KEY=AIza...
# Optional: override default (default: gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-pro
# Optional GCP: GEMINI_SECRET_RESOURCE=projects/PROJECT/secrets/NAME/versions/latest

# -- StormGlass API — Agent Meteo (optional) ----------------------------------
# If not set, the meteo agent uses LLM training data only
# STORMGLASS_API_KEY=your_stormglass_key

# -- NavSecOps — CI / GitLab integration --------------------------------------
# Shared secret for POST /api/v1/navsecops/analyze (Bearer token).
# In production / CI: set via GitLab CI variable (masked) or GCP Secret Manager.
NAVSECOPS_INGEST_SECRET=change-me-to-a-real-secret
# CI only (GitLab): set NAVSECOPS_SYNC_ENABLED=1 to persist reports via POST /api/v1/navsecops/sync-report after MR note.

# -- Server -------------------------------------------------------------------
PORT=8000
